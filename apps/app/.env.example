# ────────────────────────────────────────────────
# Arkvoid Platform — app.arkvoid.com
# Copy to .env.local — NEVER commit .env.local
# ────────────────────────────────────────────────

# Supabase (get from: supabase.com → Project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon key — safe to expose in browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — SERVER ONLY, never expose to client
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Auth redirect
NEXT_PUBLIC_AUTH_URL=https://auth.arkvoid.com

# Self reference
NEXT_PUBLIC_APP_URL=https://app.arkvoid.com
