# ────────────────────────────────────────────────
# Arkvoid Auth — auth.arkvoid.com
# Get values: supabase.com → Project → Settings → API
# Copy to .env.local — NEVER commit .env.local
# ────────────────────────────────────────────────

# Required: Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Required: Supabase anon/public key (safe for browsers)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# After login, redirect here
NEXT_PUBLIC_APP_URL=https://app.arkvoid.com

# Site URL (for OAuth redirect allow-list)
NEXT_PUBLIC_SITE_URL=https://arkvoid.com

# Support email
NEXT_PUBLIC_SUPPORT_EMAIL=heyarkvoid@gmail.com

# For local development:
# NEXT_PUBLIC_APP_URL=http://localhost:3002
